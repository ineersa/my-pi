{
  "name": "pi-mcp-adapter",
  "version": "2.4.0",
  "description": "MCP (Model Context Protocol) adapter extension for Pi coding agent",
  "type": "module",
  "license": "MIT",
  "author": "Nico Bailon",
  "bin": {
    "pi-mcp-adapter": "cli.js"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nicobailon/pi-mcp-adapter.git"
  },
  "keywords": [
    "pi-package",
    "pi",
    "mcp",
    "model-context-protocol",
    "ai",
    "coding-agent",
    "extension",
    "claude",
    "llm"
  ],
  "pi": {
    "extensions": [
      "./pi-mcp-adapter.ts"
    ],
    "video": "https://github.com/nicobailon/pi-mcp-adapter/raw/refs/heads/main/pi-mcp.mp4"
  },
  "files": [
    "cli.js",
    "pi-mcp-adapter.ts",
    "state.ts",
    "utils.ts",
    "tool-metadata.ts",
    "init.ts",
    "proxy-modes.ts",
    "direct-tools.ts",
    "commands.ts",
    "types.ts",
    "config.ts",
    "server-manager.ts",
    "tool-registrar.ts",
    "resource-tools.ts",
    "lifecycle.ts",
    "metadata-cache.ts",
    "npx-resolver.ts",
    "logger.ts",
    "errors.ts",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.1",
    "@sinclair/typebox": "^0.32.0"
  }
}
